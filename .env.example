# ── Groq (required) ───────────────────────────────────────────
# Free API key at https://console.groq.com
GROQ_API_KEY=

# ── Model settings (optional, these are the defaults) ─────────
MIND_MODEL=llama-3.3-70b-versatile
MIND_TEMPERATURE=0.2
MIND_MAX_ROUNDS=6

# ── Langfuse observability (optional) ─────────────────────────
# Run `docker compose up -d`, open http://localhost:3000,
# create a project and copy the keys from Project Settings → API Keys.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
